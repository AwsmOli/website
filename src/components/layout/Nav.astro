---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from '../../assets/blkpixel_logo.png';
import Container from '../ui/Container.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

const links = [
  { href: '/', label: 'Home' },
  { href: '/cv', label: 'CV' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About Me' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="border-b border-[var(--border)]">
  <Container class="flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold">
      <Image
        src={logo}
        alt=""
        width={28}
        height={28}
        densities={[1, 2]}
        class="h-7 w-7 rounded"
      />
      <span>blkPixel</span>
    </a>
    <div class="flex items-center gap-2">
      <nav aria-label="Main navigation" class="hidden md:block">
        <ul class="flex items-center gap-1 text-sm">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'rounded-[var(--radius-md)] px-3 py-2 transition-colors hover:bg-[var(--surface)]',
                    isActive(link.href) ? 'text-[var(--accent)]' : 'text-[var(--fg)]',
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
      <button
        id="nav-menu-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-menu-panel"
        class="flex h-9 w-9 items-center justify-center rounded-[var(--radius-md)] text-[var(--fg)] hover:bg-[var(--surface)] md:hidden"
      >
        <Icon name="lucide:menu" id="nav-menu-icon-open" class="block h-5 w-5" />
        <Icon name="lucide:x" id="nav-menu-icon-close" class="hidden h-5 w-5" />
      </button>
    </div>
  </Container>
  <nav
    id="nav-menu-panel"
    aria-label="Mobile navigation"
    class="hidden border-t border-[var(--border)] md:hidden"
  >
    <ul class="flex flex-col p-2 text-sm">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'block rounded-[var(--radius-md)] px-3 py-2 transition-colors hover:bg-[var(--surface)]',
                isActive(link.href) ? 'text-[var(--accent)]' : 'text-[var(--fg)]',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const panel = document.getElementById('nav-menu-panel');
  const iconOpen = document.getElementById('nav-menu-icon-open');
  const iconClose = document.getElementById('nav-menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = panel?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
