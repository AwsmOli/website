---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Card from '../components/ui/Card.astro';

const about = await getEntry('pages', 'about');
if (!about || about.data.type !== 'about') throw new Error('About entry missing or malformed');

const { title, description } = about.data;
const { Content } = await render(about);
---

<BaseLayout title={title} description={description}>
  <Container class="py-16">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <article class="prose prose-neutral mt-8 max-w-none dark:prose-invert">
      <Content />
    </article>

    <div class="mt-16">
      <h2 class="text-xl font-bold tracking-tight">Next Steps</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <Card href="/projects" class="p-6">
          <h3 class="font-semibold text-[var(--accent)]">Check out my Projects</h3>
          <p class="mt-2 text-sm text-[var(--muted)]">
            See what I'm building outside of client work — software, hardware, and everything in
            between.
          </p>
        </Card>
        <Card href="/contact" class="p-6">
          <h3 class="font-semibold text-[var(--accent)]">Get in Touch</h3>
          <p class="mt-2 text-sm text-[var(--muted)]">
            Always happy to talk frontend, trading systems, or hardware builds.
          </p>
        </Card>
      </div>
    </div>
  </Container>
</BaseLayout>
